{
  "name": "blue-noise",
  "version": "1.0.1",
  "description": "Blue noise dithering for images",
  "keywords": [
    "blue-noise",
    "dithering",
    "image-processing"
  ],
  "license": "MIT",
  "author": "Matthew Blode <m@blode.co>",
  "bin": {
    "blue-noise": "./dist/cli.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "changeset publish",
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "dither": "tsx src/cli.ts",
    "prepare": "lefthook install || true",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "check:types": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.1.1",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsx": "^4.23.0",
    "typescript": "7.0.2",
    "ultracite": "7.9.3"
  },
  "engines": {
    "node": ">=24"
  }
}
